{
  "name": "node-js-profiling",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "npm run dev",
    "k6:basic": "docker run --rm -i --network host -e BASE_URL=http://127.0.0.1:3000 grafana/k6 run - < load/k6/basic.js",
    "k6:basic:local": "k6 run load/k6/basic.js",
    "profile:cpu:serve": "npm run build && node --cpu-prof --cpu-prof-dir=profiles --cpu-prof-name=app-$(date +%Y%m%d-%H%M%S).cpuprofile dist/main.js",
    "profile:heap:serve": "npm run build && node --heap-prof --heap-prof-dir=profiles --heap-prof-name=app-$(date +%Y%m%d-%H%M%S).heapprofile dist/main.js",
    "profile:cpu:k6": "bash scripts/profile-cpu.sh",
    "profile:heap:k6": "bash scripts/profile-heap.sh",
    "speedscope:latest": "node scripts/speedscope-latest.js",
    "preprofile:cpu": "npm run build",
    "profile:cpu": "node --cpu-prof --cpu-prof-dir=profiles dist/main.js",
    "preprofile:heap": "npm run build",
    "profile:heap": "node --heap-prof --heap-prof-dir=profiles dist/main.js",
    "preprofile:inspect": "npm run build",
    "profile:inspect": "node --inspect=127.0.0.1:9229 dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "prom-client": "^14.2.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "speedscope": "^1.25.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
